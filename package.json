{
  "name": "tradepilot",
  "version": "1.0.0",
  "description": "TradePilot - Field Service Business Management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.tradepilot.app",
    "productName": "TradePilot",
    "copyright": "TradePilot",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TradePilot"
    },
    "files": ["main.js", "preload.js", "src/**/*", "assets/**/*", "node_modules/**/*"]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
